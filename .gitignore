# In-repo toolchain (vendored JDK, Gradle distribution + caches). Installed by
# scripts/bootstrap.sh; never committed — large, platform-specific, reproducible.
.tools/

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
gradle-app.setting

# Java
*.class
*.log
hs_err_pid*
replay_pid*

# Engine artifacts / test scratch (never commit data files or WAL/SSTable output)
*.wal
*.sst
*.db
MANIFEST-*
CURRENT
data/
/tmp-test/

# IDE
.idea/
*.iml
.vscode/
.project
.classpath
.settings/
*.swp

# OS
.DS_Store
Thumbs.db
