root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
indent_size = 2
max_line_length = 100

[*.md]
indent_size = 2
max_line_length = 90
trim_trailing_whitespace = false

[*.{gradle,gradle.kts,kt,kts}]
indent_size = 4

[*.{xml,proto}]
indent_size = 2

[*.{yml,yaml,toml,json}]
indent_size = 2

[Makefile]
indent_style = tab

# Golden files are byte-exact fixtures. Never normalise them.
[**/src/test/resources/golden/**]
insert_final_newline = false
trim_trailing_whitespace = false
